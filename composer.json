{
    "name": "psc-acme/validator-billing",
    "description": "Package validator-billing for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ValidatorBilling\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "brick/date-time": "^0.7.1",
        "league/csv": "^9.0",
        "symfony/string": "^7.0",
        "psr/http-message": "^2.0"
    },
    "require-dev": {
        "phpstan/phpstan-symfony": "^1.0",
        "symfony/phpunit-bridge": "^7.0",
        "phpstan/phpstan": "^1.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}